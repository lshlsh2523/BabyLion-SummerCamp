# 비밀값은 코드에 적지 않는다 (역할분담 5.1-1)
OPENAI_API_KEY=sk-...        # 월요일 Whisper/GPT 연동 시 사용 (백2 함수가 읽음)
MEDIA_DIR=./media            # 업로드 파일 저장 위치
DATABASE_URL=sqlite:///./babylion.db
PRIVATE_DIR=./private        # 음성 답변 등 비공개 파일 (정적 서빙 안 됨)

# NAVER CLOVA Speech 단문 인식 (STT)
CLOVA_STT_SECRET=            # 앱 등록 시 발급받은 Secret Key (X-CLOVASPEECH-API-KEY)
CLOVA_STT_URL=https://clovaspeech-gw.ncloud.com/recog/v1/stt
CLOVA_STT_LANG=Kor           # Kor / Eng / Jpn / Chn
CLOVA_STT_TIMEOUT=30
